{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@nano-bruce/ai": ["./packages/ai/src/index.ts"],
      "@nano-bruce/ai/*": ["./packages/ai/src/*"],
      "@nano-bruce/agent-core": ["./packages/agent/src/index.ts"],
      "@nano-bruce/agent-core/*": ["./packages/agent/src/*"],
      "@nano-bruce/bruce": ["./packages/bruce/src/index.ts"],
      "@nano-bruce/bruce/*": ["./packages/bruce/src/*"]
    }
  },
  "include": ["packages/*/src/**/*.ts", "packages/*/src/**/*.tsx"],
  "exclude": ["node_modules", "dist", "**/dist/**"]
}
