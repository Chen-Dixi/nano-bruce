{
  "name": "@nano-bruce/app",
  "version": "0.1.1",
  "description": "Bruce CLI app and re-exports.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "bruce": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "bun dist/cli.js",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@nano-bruce/agent-core": "0.1.1",
    "@nano-bruce/ai": "0.1.1",
    "@nano-bruce/bruce": "0.1.1"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "typescript": "^5.7.2",
    "vitest": "^3.1.2"
  },
  "engines": {
    "bun": ">=1"
  }
}
