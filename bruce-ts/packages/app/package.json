{
  "name": "@nano-bruce/agent",
  "version": "0.1.1",
  "description": "Bruce agent entry: CLI and re-exports.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "bruce-agent": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/cli.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@nano-bruce/bruce": "0.1.1",
    "@nano-bruce/ai": "0.1.1"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18"
  }
}
