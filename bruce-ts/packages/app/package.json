{
  "name": "@nano-bruce/app",
  "version": "0.1.1",
  "description": "Bruce CLI app and re-exports.",
  "type": "module",
  "main": "dist/bruce",
  "bin": {
    "bruce": "dist/bruce"
  },
  "exports": {
    ".": {
      "import": "./dist/bruce",
      "default": "./dist/bruce"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && bun scripts/build.ts",
    "start": "bun dist/cli.js",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@nano-bruce/agent-core": "0.1.1",
    "@nano-bruce/ai": "0.1.1",
    "@nano-bruce/bruce": "0.1.1",
    "@opentui/solid": "^0.2.2",
    "solid-js": "^1.9.12"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "typescript": "^5.7.2",
    "vitest": "^3.1.2"
  },
  "engines": {
    "bun": ">=1"
  }
}
